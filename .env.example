# CYT-NG Environment Configuration
# Copy to .env and fill in values

# Flask
CYT_SECRET_KEY=change-me-to-a-random-secret
FLASK_ENV=production

# Synology DSM OAuth2 SSO (optional — leave blank to disable SSO)
SYNOLOGY_DSM_URL=
SYNOLOGY_OAUTH_CLIENT_ID=
SYNOLOGY_OAUTH_CLIENT_SECRET=

# WiGLE API (optional — for SSID geolocation)
WIGLE_API_TOKEN=

# Kismet data path (mounted volume in Docker)
KISMET_DATA_PATH=/data/kismet

# CYT database path
CYT_DATABASE_PATH=/data/cyt/cyt_data.db

# TLS certificates (optional — auto-generates self-signed if empty)
TLS_CERT_PATH=
TLS_KEY_PATH=
