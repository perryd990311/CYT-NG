{
  "paths": {
    "base_dir": ".",
    "log_dir": "logs",
    "kismet_logs": "/data/kismet",
    "cyt_database": "cyt_data.db",
    "ignore_lists": {
      "mac": "ignore_lists/mac_list.json",
      "ssid": "ignore_lists/ssid_list.json"
    },
    "reports_dir": "surveillance_reports",
    "kml_dir": "kml_files"
  },
  "timing": {
    "check_interval": 60,
    "list_update_interval": 5,
    "time_windows": {
      "recent": 5,
      "medium": 10,
      "old": 15,
      "oldest": 20
    },
    "analysis_interval_hours": 6,
    "cleanup_interval_hours": 24,
    "retention_days": 90
  },
  "search": {
    "lat_min": 31.3,
    "lat_max": 37.0,
    "lon_min": -114.8,
    "lon_max": -109.0
  },
  "web": {
    "host": "0.0.0.0",
    "port": 8000,
    "secret_key_env": "CYT_SECRET_KEY",
    "debug": false
  },
  "docker": {
    "image_name": "cyt-ng",
    "nginx_port_https": 443,
    "nginx_port_http": 80,
    "volumes": {
      "kismet_data": "/data/kismet",
      "cyt_data": "/data/cyt",
      "cyt_logs": "/data/logs",
      "certs": "/certs"
    }
  },
  "sensor": {
    "sync_interval_minutes": 5,
    "smb_share": "//172.20.0.250/kismet_data",
    "health_check_interval_minutes": 10
  },
  "fingerprinting": {
    "jaccard_threshold": 0.85,
    "min_ssids_for_fingerprint": 2
  }
}